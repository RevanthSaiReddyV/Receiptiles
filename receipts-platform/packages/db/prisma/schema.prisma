generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  emailVerified   DateTime?
  passwordHash    String?
  image           String?
  pushToken       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  receipts              Receipt[]
  ingestionJobs         IngestionJob[]
  emailConnections      EmailConnection[]
  cards                 UserCard[]
  merchantConnections   MerchantConnection[]
  customerConnections   CustomerConnection[]
  apiKeys               ApiKey[]
  walletPasses          WalletPass[]
  subscriptions         Subscription[]
  passwordResetTokens   PasswordResetToken[]
  spendingSnapshots     SpendingSnapshot[]
  merchantVisits        MerchantVisit[]
  locationInsights      LocationInsight[]
  retailerConnections   RetailerConnection[]
  budgets               Budget[]
  signupBonusGoals      SignupBonusGoal[]
  receiptWallet         ReceiptWallet?
  referralsSent         Referral[]        @relation("referralsSent")
  referralsReceived     Referral[]        @relation("referralsReceived")
  referralRewards       ReferralReward[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String
  key         String   @unique
  prefix      String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  rateLimit   Int      @default(100)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum ReceiptSource {
  UPLOAD
  EMAIL
  POS
  PROCESSOR
  MANUAL
  RETAILER
}

model Receipt {
  id        String        @id @default(cuid())
  userId    String
  source    ReceiptSource
  sourceId  String?       // External ID for dedup (e.g., "costco-2024-01-01-125.99")
  sourceRetailer String?  // Retailer connector ID (e.g., "amazon", "costco")
  fileUrl   String?

  // Merchant
  merchantRawName       String
  merchantCanonicalName String
  merchantCategory      String    @default("Uncategorized")
  merchantLocation      String?

  // Purchase
  purchasedAt DateTime
  currency    String   @default("USD")
  subtotal    Float
  tax         Float    @default(0)
  tip         Float    @default(0)
  discount    Float    @default(0)
  fees        Float    @default(0)
  total       Float

  // Payment
  paymentMethod String  @default("unknown")
  cardId        String?
  cardLast4     String?
  walletType    String?
  entryMode     String?

  // Metadata
  confidence     Float    @default(0)
  requiresReview Boolean  @default(false)
  ocrText        String?  @db.Text
  rawParseResult Json?
  receiptUrl     String?  // Original receipt URL from POS (e.g., Square receipt_url)

  // Warranty & Return Tracking (for Apple Wallet Orders)
  warrantyExpiresAt  DateTime?  // Calculated warranty expiry based on category
  returnExpiresAt    DateTime?  // Return window expiry

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ReceiptItem[]
  card  UserCard?     @relation(fields: [cardId], references: [id])

  @@index([userId])
  @@index([userId, purchasedAt])
  @@index([merchantCanonicalName])
  @@index([sourceId])
  @@index([sourceRetailer])
  @@unique([userId, sourceId], name: "receipt_source_dedup")
}

model ReceiptItem {
  id          String  @id @default(cuid())
  receiptId   String
  rawName     String
  name        String
  description String?
  imageUrl    String?
  quantity    Float   @default(1)
  unitPrice   Float
  totalPrice  Float
  category    String  @default("Uncategorized")
  sku         String?
  productUrl  String?

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model IngestionJob {
  id        String    @id @default(cuid())
  userId    String
  source    ReceiptSource
  status    JobStatus @default(PENDING)
  fileUrl   String?
  fileName  String?
  fileSize  Int?
  error     String?   @db.Text
  receiptId String?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model EmailConnection {
  id           String   @id @default(cuid())
  userId       String
  provider     String   @default("gmail")
  email        String
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime?
  lastSyncAt   DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}

model UserCard {
  id           String  @id @default(cuid())
  userId       String
  name         String
  last4        String
  network      String
  issuer       String?
  expMonth     Int?
  expYear      Int?
  cardColor    String?  // dominant color from card scan
  cardImageUrl String?  // user's own card photo (blurred number)
  isDefault    Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardRules CardRewardRule[]
  receipts    Receipt[]

  @@index([userId])
}

model CardRewardRule {
  id           String  @id @default(cuid())
  cardId       String
  category     String?
  merchantName String?
  rewardRate   Float
  rewardType   String  @default("cashback")
  multiplier   Float   @default(1)
  createdAt    DateTime @default(now())

  card UserCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model MerchantConnection {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  merchantId   String
  merchantName String?
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  locationId   String?
  metadata     Json?
  isActive     Boolean  @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, merchantId])
  @@index([userId])
  @@index([provider])
}

model CustomerConnection {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  accountId    String
  email        String?
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  metadata     Json?
  isActive     Boolean  @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, accountId])
  @@index([userId])
}

// ─── POS Hardware & Webhook Integration ─────────────────────────────────────

enum DeviceStatus {
  ACTIVE
  INACTIVE
  PROVISIONING
}

model Device {
  id           String       @id @default(cuid())
  merchantId   String?      // links to MerchantConnection if claimed
  deviceSerial String       @unique
  name         String?
  firmware     String?
  status       DeviceStatus @default(PROVISIONING)
  apiKey       String       @unique // device auth key (dk_<hex>)
  locationId   String?
  posType      String?      // "epson", "star", "citizen"
  connectionType String?    // "serial", "usb", "ethernet"
  lastSeenAt   DateTime?
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  webhookEvents WebhookEvent[]

  @@index([apiKey])
  @@index([merchantId])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String   // "square", "toast", "shopify", "device"
  eventType   String   // "payment.completed", "order.paid", "receipt.parsed"
  externalId  String?  // provider's event ID for dedup
  deviceId    String?
  payload     Json
  status      String   @default("pending") // pending, processed, failed, skipped
  error       String?  @db.Text
  receiptId   String?  // links to created receipt if processed
  processedAt DateTime?
  createdAt   DateTime @default(now())

  device Device? @relation(fields: [deviceId], references: [id])

  @@index([provider, externalId])
  @@index([status])
  @@index([deviceId])
}

model WalletPass {
  id             String   @id @default(cuid())
  userId         String
  platform       String   // "apple", "google"
  passTypeId     String?  // Apple: pass type identifier
  serialNumber   String   @unique
  authToken      String   // pass auth for push updates
  pushToken      String?  // APNs push token for Apple
  lastUpdatedAt  DateTime @default(now())
  receiptCount   Int      @default(0)
  isActive       Boolean  @default(true)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Device info for multi-device tracking
  deviceId       String?  // fingerprint hash for this device
  deviceName     String?  // "iPhone 15 Pro", "Pixel 8", "MacBook Pro"
  deviceType     String?  // "mobile", "tablet", "desktop", "watch"
  osName         String?  // "iOS", "Android", "macOS", "Windows"
  osVersion      String?  // "17.4", "14", "14.5"
  browserName    String?  // "Safari", "Chrome", "Mobile App"
  screenWidth    Int?
  screenHeight   Int?
  userAgent      String?
  ipAddress      String?
  lastActiveAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([serialNumber])
  @@index([userId])
  @@index([deviceId])
}

// ─── Data Monetization ──────────────────────────────────────────────────────

enum DataApiTier {\n  FREE
  TRIAL
  STANDARD
  ENTERPRISE
}

model DataApiKey {
  id           String      @id @default(cuid())
  userId       String?     // Developer who created this key
  key          String      @unique // dat_<hex>
  partnerId    String      @map("partner_id")
  partnerName  String      @map("partner_name")
  tier         DataApiTier @default(TRIAL)
  active       Boolean     @default(true)
  contactEmail String?
  description  String?
  requestCount Int         @default(0)
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  usageLogs DataApiUsageLog[]

  @@index([key])
  @@index([partnerId])
  @@index([userId])
}

model DataApiUsageLog {
  id         String   @id @default(cuid())
  apiKeyId   String
  endpoint   String   // e.g. "/api/v1/data/aggregates"
  params     Json?    // query params used
  responseMs Int?     // response time in ms
  status     Int      // HTTP status code
  createdAt  DateTime @default(now())

  apiKey DataApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@index([endpoint, createdAt])
}

// ─── Subscription Detection ─────────────────────────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum SubscriptionFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  ANNUAL
}

model Subscription {
  id              String                @id @default(cuid())
  userId          String
  merchantName    String
  category        String?
  amount          Float
  frequency       SubscriptionFrequency
  status          SubscriptionStatus    @default(ACTIVE)
  confidence      Float                 @default(0) // 0-1 detection confidence
  nextExpectedAt  DateTime?
  lastChargeAt    DateTime?
  firstDetectedAt DateTime
  cancelledAt     DateTime?
  alertsEnabled   Boolean               @default(true)
  notes           String?
  metadata        Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts SubscriptionAlert[]
  charges SubscriptionCharge[]

  @@unique([userId, merchantName, frequency])
  @@index([userId, status])
  @@index([nextExpectedAt])
}

model SubscriptionCharge {
  id              String   @id @default(cuid())
  subscriptionId  String
  receiptId       String?
  amount          Float
  chargedAt       DateTime
  createdAt       DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, chargedAt])
}

model SubscriptionAlert {
  id              String   @id @default(cuid())
  subscriptionId  String
  type            String   // "upcoming_renewal", "price_increase", "missed_charge", "new_detected"
  title           String
  message         String
  amount          Float?
  scheduledFor    DateTime
  sentAt          DateTime?
  dismissedAt     DateTime?
  createdAt       DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([scheduledFor, sentAt])
}

// ─── ANALYTICS TABLES ──────────────────────────────────────

model SpendingSnapshot {
  id        String   @id @default(cuid())
  userId    String
  period    String   // "2026-05" monthly period
  category  String
  total     Float
  count     Int
  avgAmount Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period, category])
  @@index([period])
  @@index([category])
}

model MerchantVisit {
  id           String   @id @default(cuid())
  userId       String
  merchantName String
  category     String
  visitDate    DateTime
  amount       Float
  location     String?
  dayOfWeek    Int
  hourOfDay    Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, merchantName])
  @@index([merchantName, visitDate])
  @@index([category, visitDate])
}

model LocationInsight {
  id        String   @id @default(cuid())
  userId    String
  lat       Float
  lng       Float
  merchant  String
  category  String?
  amount    Float?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([merchant])
}

// ─── RETAILER CONNECTIONS ──────────────────────────────────

model RetailerConnection {
  id           String    @id @default(cuid())
  userId       String
  retailer     String    // "costco", "amazon", "walmart", "target"
  authToken    String    @db.Text
  refreshToken String?   @db.Text
  clientId     String?
  membershipId String?
  metadata     Json?
  lastSyncAt   DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, retailer])
  @@index([userId])
}

// ─── AI-GENERATED PARSERS ──────────────────────────────────

model RetailerParser {
  id            String   @id @default(cuid())
  senderDomain  String   @unique  // e.g., "amazon.com", "bestbuy.com"
  retailerName  String              // "Amazon", "Best Buy"
  category      String              // "Shopping", "Electronics"
  parseRules    Json                // AI-generated extraction rules
  sampleSubject String?             // example subject for reference
  successCount  Int      @default(0) // how many times this parser succeeded
  failCount     Int      @default(0) // how many times it failed
  lastUsedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([senderDomain])
}

// ─── BUDGETS ──────────────────────────────────────────────────────────────

model Budget {
  id           String   @id @default(cuid())
  userId       String
  category     String   // "Dining", "Groceries", "Gas", etc.
  monthlyLimit Float    // Monthly spending limit in dollars
  alertAt      Float?   // Alert when spending reaches this % (e.g., 0.8 = 80%)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
}

// ─── SIGNUP BONUS TRACKING ────────────────────────────────────────────────

model SignupBonusGoal {
  id           String   @id @default(cuid())
  userId       String
  cardId       String   // UserCard ID
  cardName     String   // Display name
  targetSpend  Float    // e.g., 4000
  currentSpend Float    @default(0)
  bonusValue   String   // e.g., "60,000 points"
  deadline     DateTime // Must hit target by this date
  startDate    DateTime @default(now())
  isComplete   Boolean  @default(false)
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isComplete])
  @@index([deadline])
}

// ─── UNIVERSAL RECEIPT WALLET (Consumer Identity Layer) ─────────────────────

model ReceiptWallet {
  id             String   @id @default(cuid())
  userId         String   @unique
  walletId       String   @unique // Public wallet identifier: "rw_<nanoid>"
  displayName    String?
  avatarUrl      String?
  isPublic       Boolean  @default(false) // Allow merchants to push receipts
  nfcEnabled     Boolean  @default(true)
  pushEnabled    Boolean  @default(true)
  totalReceipts  Int      @default(0)
  totalSpent     Float    @default(0)
  memberSince    DateTime @default(now())
  lastActivityAt DateTime @default(now())
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchantLinks WalletMerchantLink[]
  dataGrants    DataApiGrant[]

  @@index([walletId])
}

// Links a wallet to a merchant's loyalty/receipt system
model WalletMerchantLink {
  id             String   @id @default(cuid())
  walletId       String
  merchantId     String   // Canonical merchant identifier
  merchantName   String
  loyaltyId      String?  // Costco membership, Target Circle ID, etc.
  externalUserId String?  // User's ID in the merchant's system
  isVerified     Boolean  @default(false)
  linkedAt       DateTime @default(now())
  lastReceiptAt  DateTime?
  receiptCount   Int      @default(0)
  metadata       Json?

  wallet ReceiptWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, merchantId])
  @@index([walletId])
  @@index([merchantId])
}

// OAuth grants for third-party apps accessing user's receipt data
model DataApiGrant {
  id          String    @id @default(cuid())
  walletId    String
  appId       String    // Third-party app ID
  appName     String
  scopes      String[]  // "receipts.read", "spending.read", "items.read"
  grantedAt   DateTime  @default(now())
  expiresAt   DateTime?
  revokedAt   DateTime?
  lastUsedAt  DateTime?

  wallet ReceiptWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, appId])
  @@index([walletId])
  @@index([appId])
}

// Referral system for viral growth
model Referral {
  id             String    @id @default(cuid())
  referrerId     String    // User who shared the referral
  refereeId      String?   // User who signed up (null until claimed)
  code           String    @unique // Short code like "TIGER2024"
  deepLink       String?   // Full deep link URL
  channel        String?   // "sms", "email", "social", "copy", "qr"
  status         String    @default("pending") // "pending", "claimed", "rewarded", "expired"
  rewardType     String    @default("receipt_boost") // Type of reward
  rewardAmount   Float     @default(0)
  rewardClaimed  Boolean   @default(false)
  expiresAt      DateTime?
  claimedAt      DateTime?
  rewardedAt     DateTime?
  createdAt      DateTime  @default(now())

  referrer User  @relation("referralsSent", fields: [referrerId], references: [id], onDelete: Cascade)
  referee  User? @relation("referralsReceived", fields: [refereeId], references: [id])

  @@index([referrerId])
  @@index([refereeId])
  @@index([code])
  @@index([status])
}

// Referral rewards ledger
model ReferralReward {
  id          String   @id @default(cuid())
  userId      String
  referralId  String
  type        String   // "referrer_bonus", "referee_welcome", "milestone"
  description String
  amount      Float    @default(0)
  currency    String   @default("points") // "points", "cash", "premium_days"
  claimedAt   DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([referralId])
}

// Card-linked offers from merchants
model CardLinkedOffer {
  id               String    @id @default(cuid())
  merchantId       String    // Partner merchant ID
  merchantName     String
  merchantLogo     String?
  title            String
  description      String
  type             String    @default("cashback") // "cashback", "points_multiplier", "free_item", "discount"
  cashbackPercent  Float?    // e.g., 5.0 = 5% back
  cashbackMax      Float?    // Max cashback amount
  minSpend         Float?    // Minimum purchase amount
  category         String?
  targetAudience   String    @default("all") // "all", "new", "lapsed", "vip"
  targetCategories String[]  // Categories user must shop in
  targetMerchants  String[]  // Merchants user must frequent
  priority         Int       @default(0)
  active           Boolean   @default(true)
  activationCount  Int       @default(0)
  redemptionCount  Int       @default(0)
  budget           Float?    // Total budget for this offer
  budgetUsed       Float     @default(0)
  startsAt         DateTime  @default(now())
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  activations UserOfferActivation[]

  @@index([merchantId])
  @@index([active, expiresAt])
  @@index([category])
}

// User's activated offers
model UserOfferActivation {
  id          String    @id @default(cuid())
  userId      String
  offerId     String
  activatedAt DateTime  @default(now())
  redeemedAt  DateTime? // When the cashback was earned
  rewardAmount Float?   // Actual cashback earned
  receiptId   String?   // Receipt that triggered redemption
  createdAt   DateTime  @default(now())

  offer CardLinkedOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([userId, offerId])
  @@index([userId])
  @@index([offerId])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("landing")
  createdAt DateTime @default(now())
}
