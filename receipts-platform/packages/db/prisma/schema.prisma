generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  pushToken     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  receipts              Receipt[]
  ingestionJobs         IngestionJob[]
  emailConnections      EmailConnection[]
  cards                 UserCard[]
  merchantConnections   MerchantConnection[]
  customerConnections   CustomerConnection[]
  apiKeys               ApiKey[]
  walletPasses          WalletPass[]
  subscriptions         Subscription[]
  passwordResetTokens   PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String
  key         String   @unique
  prefix      String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  rateLimit   Int      @default(100)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum ReceiptSource {
  UPLOAD
  EMAIL
  POS
  PROCESSOR
  MANUAL
}

model Receipt {
  id        String        @id @default(cuid())
  userId    String
  source    ReceiptSource
  fileUrl   String?

  // Merchant
  merchantRawName       String
  merchantCanonicalName String
  merchantCategory      String    @default("Uncategorized")
  merchantLocation      String?

  // Purchase
  purchasedAt DateTime
  currency    String   @default("USD")
  subtotal    Float
  tax         Float    @default(0)
  tip         Float    @default(0)
  discount    Float    @default(0)
  fees        Float    @default(0)
  total       Float

  // Payment
  paymentMethod String  @default("unknown")
  cardId        String?
  cardLast4     String?
  walletType    String?
  entryMode     String?

  // Metadata
  confidence     Float    @default(0)
  requiresReview Boolean  @default(false)
  ocrText        String?  @db.Text
  rawParseResult Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ReceiptItem[]
  card  UserCard?     @relation(fields: [cardId], references: [id])

  @@index([userId])
  @@index([userId, purchasedAt])
  @@index([merchantCanonicalName])
}

model ReceiptItem {
  id         String @id @default(cuid())
  receiptId  String
  rawName    String
  name       String
  quantity   Float  @default(1)
  unitPrice  Float
  totalPrice Float
  category   String @default("Uncategorized")

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model IngestionJob {
  id        String    @id @default(cuid())
  userId    String
  source    ReceiptSource
  status    JobStatus @default(PENDING)
  fileUrl   String?
  fileName  String?
  fileSize  Int?
  error     String?   @db.Text
  receiptId String?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model EmailConnection {
  id           String   @id @default(cuid())
  userId       String
  provider     String   @default("gmail")
  email        String
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime?
  lastSyncAt   DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}

model UserCard {
  id        String  @id @default(cuid())
  userId    String
  name      String
  last4     String
  network   String
  issuer    String?
  isDefault Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardRules CardRewardRule[]
  receipts    Receipt[]

  @@index([userId])
}

model CardRewardRule {
  id           String  @id @default(cuid())
  cardId       String
  category     String?
  merchantName String?
  rewardRate   Float
  rewardType   String  @default("cashback")
  multiplier   Float   @default(1)
  createdAt    DateTime @default(now())

  card UserCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model MerchantConnection {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  merchantId   String
  merchantName String?
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  locationId   String?
  metadata     Json?
  isActive     Boolean  @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, merchantId])
  @@index([userId])
  @@index([provider])
}

model CustomerConnection {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  accountId    String
  email        String?
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  metadata     Json?
  isActive     Boolean  @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, accountId])
  @@index([userId])
}

// ─── POS Hardware & Webhook Integration ─────────────────────────────────────

enum DeviceStatus {
  ACTIVE
  INACTIVE
  PROVISIONING
}

model Device {
  id           String       @id @default(cuid())
  merchantId   String?      // links to MerchantConnection if claimed
  deviceSerial String       @unique
  name         String?
  firmware     String?
  status       DeviceStatus @default(PROVISIONING)
  apiKey       String       @unique // device auth key (dk_<hex>)
  locationId   String?
  posType      String?      // "epson", "star", "citizen"
  connectionType String?    // "serial", "usb", "ethernet"
  lastSeenAt   DateTime?
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  webhookEvents WebhookEvent[]

  @@index([apiKey])
  @@index([merchantId])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String   // "square", "toast", "shopify", "device"
  eventType   String   // "payment.completed", "order.paid", "receipt.parsed"
  externalId  String?  // provider's event ID for dedup
  deviceId    String?
  payload     Json
  status      String   @default("pending") // pending, processed, failed, skipped
  error       String?  @db.Text
  receiptId   String?  // links to created receipt if processed
  processedAt DateTime?
  createdAt   DateTime @default(now())

  device Device? @relation(fields: [deviceId], references: [id])

  @@index([provider, externalId])
  @@index([status])
  @@index([deviceId])
}

model WalletPass {
  id             String   @id @default(cuid())
  userId         String
  platform       String   // "apple", "google"
  passTypeId     String?  // Apple: pass type identifier
  serialNumber   String   @unique
  authToken      String   // pass auth for push updates
  pushToken      String?  // APNs push token for Apple
  lastUpdatedAt  DateTime @default(now())
  receiptCount   Int      @default(0)
  isActive       Boolean  @default(true)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([serialNumber])
  @@index([userId])
}

// ─── Data Monetization ──────────────────────────────────────────────────────

enum DataApiTier {
  TRIAL
  STANDARD
  ENTERPRISE
}

model DataApiKey {
  id           String      @id @default(cuid())
  key          String      @unique // dat_<hex>
  partnerId    String      @map("partner_id")
  partnerName  String      @map("partner_name")
  tier         DataApiTier @default(TRIAL)
  active       Boolean     @default(true)
  contactEmail String?
  description  String?
  requestCount Int         @default(0)
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  usageLogs DataApiUsageLog[]

  @@index([key])
  @@index([partnerId])
}

model DataApiUsageLog {
  id         String   @id @default(cuid())
  apiKeyId   String
  endpoint   String   // e.g. "/api/v1/data/aggregates"
  params     Json?    // query params used
  responseMs Int?     // response time in ms
  status     Int      // HTTP status code
  createdAt  DateTime @default(now())

  apiKey DataApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@index([endpoint, createdAt])
}

// ─── Subscription Detection ─────────────────────────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum SubscriptionFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  ANNUAL
}

model Subscription {
  id              String                @id @default(cuid())
  userId          String
  merchantName    String
  category        String?
  amount          Float
  frequency       SubscriptionFrequency
  status          SubscriptionStatus    @default(ACTIVE)
  confidence      Float                 @default(0) // 0-1 detection confidence
  nextExpectedAt  DateTime?
  lastChargeAt    DateTime?
  firstDetectedAt DateTime
  cancelledAt     DateTime?
  alertsEnabled   Boolean               @default(true)
  notes           String?
  metadata        Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts SubscriptionAlert[]
  charges SubscriptionCharge[]

  @@unique([userId, merchantName, frequency])
  @@index([userId, status])
  @@index([nextExpectedAt])
}

model SubscriptionCharge {
  id              String   @id @default(cuid())
  subscriptionId  String
  receiptId       String?
  amount          Float
  chargedAt       DateTime
  createdAt       DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, chargedAt])
}

model SubscriptionAlert {
  id              String   @id @default(cuid())
  subscriptionId  String
  type            String   // "upcoming_renewal", "price_increase", "missed_charge", "new_detected"
  title           String
  message         String
  amount          Float?
  scheduledFor    DateTime
  sentAt          DateTime?
  dismissedAt     DateTime?
  createdAt       DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([scheduledFor, sentAt])
}
