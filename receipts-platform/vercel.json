{
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm turbo build --filter=@receipts/web",
  "outputDirectory": "apps/web/.next",
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/subscriptions",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/retailer-sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/health-ping",
      "schedule": "*/5 * * * *"
    }
  ]
}
