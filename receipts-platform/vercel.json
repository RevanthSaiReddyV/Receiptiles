{
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "npx prisma generate --schema=packages/db/prisma/schema.prisma && cd apps/web && npx next build",
  "outputDirectory": "apps/web/.next",
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/subscriptions",
      "schedule": "0 7 * * *"
    }
  ]
}
