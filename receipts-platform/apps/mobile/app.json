{
  "expo": {
    "name": "Receipts",
    "slug": "receipts",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "receipts",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.receiptsplatform.app",
      "associatedDomains": [
        "applinks:receipts.app",
        "applinks:*.receipts.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of receipts to import them.",
        "NSPhotoLibraryUsageDescription": "Select receipt images from your photo library.",
        "NFCReaderUsageDescription": "Read NFC tags at point-of-sale terminals to receive digital receipts.",
        "NSLocationWhenInUseUsageDescription": "Your location helps us recommend the best credit card for nearby merchants.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Background location enables card recommendations when you arrive at a store.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.receiptsplatform.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.NFC",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "receipts.app",
              "pathPrefix": "/claim"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-secure-store",
      "expo-location",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#000000"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2fbc2647-2923-452e-b665-89140cbe606b"
      }
    },
    "owner": "revanthsaireddy",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/2fbc2647-2923-452e-b665-89140cbe606b"
    }
  }
}
