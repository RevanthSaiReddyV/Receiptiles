{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://receipts-platform-revanth-sai-reddy-venumbaka-s-projects.vercel.app"
      }
    },
    "development:simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://receipts-platform-revanth-sai-reddy-venumbaka-s-projects.vercel.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "resourceClass": "m-medium",
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://receipts-platform-revanth-sai-reddy-venumbaka-s-projects.vercel.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "revanthsaireddy27@gmail.com",
        "ascAppId": "6772715574",
        "appleTeamId": "37UQ6CRVCF"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services.json",
        "track": "production"
      }
    }
  }
}
