# =============================================================================
# Development Environment Configuration
# Copy to .env.local and fill in your actual values
# =============================================================================

# Database (Neon dev branch)
DATABASE_URL="postgresql://user:password@ep-dev-branch-123.us-east-2.aws.neon.tech/receipts?sslmode=require"

# Auth
NEXTAUTH_SECRET="dev-secret-change-me"
NEXTAUTH_URL="http://localhost:3000"

# Google Cloud Vision (OCR)
GOOGLE_CLOUD_PROJECT_ID=""
GOOGLE_CLOUD_CREDENTIALS=""

# OpenAI (GPT-4o parsing)
OPENAI_API_KEY=""

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="receipts-dev"
R2_PUBLIC_URL=""

# Gmail API
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# POS Connectors - Square
SQUARE_APP_ID=""
SQUARE_APP_SECRET=""

# POS Connectors - Shopify
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""

# POS Connectors - Clover
CLOVER_APP_ID=""
CLOVER_APP_SECRET=""

# Customer Connectors - PayPal
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_SANDBOX="true"

# Customer Connectors - Shopify Storefront (customer-facing)
SHOPIFY_STOREFRONT_ID=""
SHOPIFY_STOREFRONT_SECRET=""

# Cron (Vercel Cron secret for auto-sync)
CRON_SECRET="dev-cron-secret"

# POS Webhooks (signature verification)
SQUARE_WEBHOOK_SIGNATURE_KEY=""
TOAST_WEBHOOK_SECRET=""
SHOPIFY_WEBHOOK_SECRET=""

# Device Provisioning (ESP32 hardware)
DEVICE_PROVISION_KEY=""

# Apple Wallet (PassKit)
APPLE_TEAM_ID=""
APPLE_PASS_TYPE_ID="pass.com.receipts.master"

# Google Wallet
GOOGLE_WALLET_ISSUER_ID=""
GOOGLE_WALLET_SERVICE_ACCOUNT_KEY=""

# Gemini AI (primary receipt parser)
GEMINI_API_KEY=""

# Resend (outbound email)
RESEND_API_KEY=""
EMAIL_FROM="receipts@updates.receiptsvault.com"

# Universal Links / App Links
ANDROID_SHA256_FINGERPRINT=""

# Sentry (disabled in dev by default — uncomment to test)
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# Logging
LOG_LEVEL="debug"
