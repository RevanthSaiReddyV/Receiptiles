# =============================================================================
# Production Environment Configuration
# These values are set in Vercel Environment Variables for the Production environment
# =============================================================================

# Database (Neon production)
DATABASE_URL="postgresql://user:password@ep-prod-main-789.us-east-2.aws.neon.tech/receipts?sslmode=require"

# Auth
NEXTAUTH_SECRET="<set-in-vercel>"
NEXTAUTH_URL="https://receiptiles.com"

# Google Cloud Vision (OCR)
GOOGLE_CLOUD_PROJECT_ID="<set-in-vercel>"
GOOGLE_CLOUD_CREDENTIALS="<set-in-vercel>"

# OpenAI (GPT-4o parsing)
OPENAI_API_KEY="<set-in-vercel>"

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID="<set-in-vercel>"
R2_ACCESS_KEY_ID="<set-in-vercel>"
R2_SECRET_ACCESS_KEY="<set-in-vercel>"
R2_BUCKET_NAME="receipts"
R2_PUBLIC_URL="<set-in-vercel>"

# Gmail API
GOOGLE_CLIENT_ID="<set-in-vercel>"
GOOGLE_CLIENT_SECRET="<set-in-vercel>"

# POS Connectors - Square
SQUARE_APP_ID="<set-in-vercel>"
SQUARE_APP_SECRET="<set-in-vercel>"

# POS Connectors - Shopify
SHOPIFY_CLIENT_ID="<set-in-vercel>"
SHOPIFY_CLIENT_SECRET="<set-in-vercel>"

# POS Connectors - Clover
CLOVER_APP_ID="<set-in-vercel>"
CLOVER_APP_SECRET="<set-in-vercel>"

# Customer Connectors - PayPal
PAYPAL_CLIENT_ID="<set-in-vercel>"
PAYPAL_CLIENT_SECRET="<set-in-vercel>"
PAYPAL_SANDBOX="false"

# Customer Connectors - Shopify Storefront (customer-facing)
SHOPIFY_STOREFRONT_ID="<set-in-vercel>"
SHOPIFY_STOREFRONT_SECRET="<set-in-vercel>"

# Cron (Vercel Cron secret for auto-sync)
CRON_SECRET="<set-in-vercel>"

# POS Webhooks (signature verification)
SQUARE_WEBHOOK_SIGNATURE_KEY="<set-in-vercel>"
TOAST_WEBHOOK_SECRET="<set-in-vercel>"
SHOPIFY_WEBHOOK_SECRET="<set-in-vercel>"

# Device Provisioning (ESP32 hardware)
DEVICE_PROVISION_KEY="<set-in-vercel>"

# Apple Wallet (PassKit)
APPLE_TEAM_ID="<set-in-vercel>"
APPLE_PASS_TYPE_ID="pass.com.receipts.master"

# Google Wallet
GOOGLE_WALLET_ISSUER_ID="<set-in-vercel>"
GOOGLE_WALLET_SERVICE_ACCOUNT_KEY="<set-in-vercel>"

# Gemini AI (primary receipt parser)
GEMINI_API_KEY="<set-in-vercel>"

# Resend (outbound email)
RESEND_API_KEY="<set-in-vercel>"
EMAIL_FROM="receipts@updates.receiptsvault.com"

# Universal Links / App Links
ANDROID_SHA256_FINGERPRINT="<set-in-vercel>"

# Sentry
NEXT_PUBLIC_SENTRY_DSN="<set-in-vercel>"
SENTRY_ORG="<set-in-vercel>"
SENTRY_PROJECT="<set-in-vercel>"

# PostHog (product analytics)
NEXT_PUBLIC_POSTHOG_KEY="<set-in-vercel>"
NEXT_PUBLIC_POSTHOG_HOST="<set-in-vercel>"
POSTHOG_API_KEY="<set-in-vercel>"
POSTHOG_HOST="<set-in-vercel>"

# Upstash Redis (rate limiting, caching)
UPSTASH_REDIS_REST_URL="<set-in-vercel>"
UPSTASH_REDIS_REST_TOKEN="<set-in-vercel>"

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID="<set-in-vercel>"
TWILIO_AUTH_TOKEN="<set-in-vercel>"
TWILIO_PHONE_NUMBER="<set-in-vercel>"

# Logging
LOG_LEVEL="warn"
